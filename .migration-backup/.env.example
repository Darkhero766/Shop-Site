# Supabase — required
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin panel access — set to the email address of the admin user
VITE_ADMIN_EMAIL=admin@example.com

# --- API Server (only needed if running the Express backend) ---

# PostgreSQL connection string (auto-provided by Render when using render.yaml)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Restrict API CORS to your frontend domain (optional but recommended in production)
# e.g. https://shopy-frontend.onrender.com
ALLOWED_ORIGIN=https://your-frontend-domain.com
